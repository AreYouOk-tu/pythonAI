# ================================================
# 环境变量配置模板
# ================================================
# 使用说明：
#   1. 复制这个文件，重命名为 .env
#   2. 把下面的值替换成你自己的真实配置
#   3. .env 文件不会提交到 Git（已加入 .gitignore）
# ================================================

# Anthropic Claude API Key
# 获取地址: https://console.anthropic.com/
# 格式：sk-ant-api03-xxxxxxxx
ANTHROPIC_API_KEY=your_api_key_here

# 使用的 Claude 模型（可选，有默认值）
# 可选值: claude-sonnet-4-6 / claude-haiku-4-5-20251001 / claude-opus-4-6
CLAUDE_MODEL=claude-sonnet-4-6

# ================================
# PostgreSQL 数据库配置
# ================================
DB_HOST=localhost        # 数据库服务器地址，本地开发填 localhost
DB_PORT=5432             # PostgreSQL 默认端口
DB_USER=postgres         # 数据库用户名
DB_PASSWORD=你的数据库密码
DB_NAME=hr_db            # 数据库名称（需要提前在 PostgreSQL 中创建）
